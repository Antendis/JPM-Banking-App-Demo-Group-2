datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int               @id @default(autoincrement())
  name          String
  email         String            @unique
  passwordHash  String            @default("")
  otpCode       String?
  otpExpiry     DateTime?
  isVerified    Boolean           @default(false)
  balance       Float             @default(0)
  accountNumber String?           @unique
  sortCode      String            @default("30-00-01")
  createdAt     DateTime          @default(now())
  pots          PotMember[]
  transactions  Transaction[]
  contributions PotContribution[]
  createdPots   Pot[]             @relation("PotCreator")
}

model Pot {
  id            Int               @id @default(autoincrement())
  title         String
  description   String?
  totalSaved    Float             @default(0)
  target        Float
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  creatorId     Int?
  creator       User?             @relation("PotCreator", fields: [creatorId], references: [id])
  members       PotMember[]
  contributions PotContribution[]
}

model PotMember {
  id     Int  @id @default(autoincrement())
  userId Int
  potId  Int
  user   User @relation(fields: [userId], references: [id])
  pot    Pot  @relation(fields: [potId], references: [id])

  @@unique([userId, potId])
}

model PotContribution {
  id        Int      @id @default(autoincrement())
  amount    Float
  note      String?
  createdAt DateTime @default(now())
  userId    Int
  potId     Int
  user      User     @relation(fields: [userId], references: [id])
  pot       Pot      @relation(fields: [potId], references: [id])
}

model Transaction {
  id           Int      @id @default(autoincrement())
  amount       Float
  description  String
  category     String
  counterparty String?
  reference    String?
  type         String
  createdAt    DateTime @default(now())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
}
